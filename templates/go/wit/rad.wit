package radcomp:extension;

interface types {
    variant target {
        llm,
        process(s32),
    }

    variant timeout-policy {
        dynamic(dynamic-policy),
        infinite,
    }

    record dynamic-policy {
        heartbeat-timeout-ms: u64,
        max-silent-wait-ms: u64,
    }

    record pending-tool-call-info {
        id: string,
        name: string,
        arguments: string,
        pgid: option<s32>,
    }

    variant ras-core-event {
        http-chunk-received(string),
        http-error-received(string),
        tool-call-requested(tool-call-request),
        process-spawned(process-spawn-info),
        process-stdout(process-output),
        process-stderr(process-output),
        process-exited(process-exit-info),
        file-changed(file-change-info),
        stream-timeout(stream-timeout-info),
        human-input-received(string),
        task-completed,
        rehydrate(list<pending-tool-call-info>),
        mcp-response(mcp-response-payload),
    }

    record mcp-response-payload {
        call-id: string,
        name: string,
        message: string,
    }

    record tool-call-request {
        call-id: string,
        name: string,
        args: string, // JSON string
    }

    record process-spawn-info {
        pgid: s32,
        pid: s32,
    }

    record process-output {
        pgid: s32,
        data: list<u8>,
    }

    record process-exit-info {
        pgid: s32,
        exit-code: option<s32>,
    }

    record file-change-info {
        path: string,
        change-type: string,
    }

    record stream-timeout-info {
        target: string,
        duration-ms: u64,
    }

    variant ras-rpc-command {
        file-read(string),
        file-write(file-write-payload),
        file-edit-patch(file-patch-payload),
        spawn-bash-process(string),
        create-node(create-node-payload),
        set-node-text(set-node-text-payload),
        merge-nodes(merge-nodes-payload),
        delete-node(string),
        take-snapshot(take-snapshot-payload),
        checkout-snapshot(string),
        open-http-stream(open-http-stream-payload),
        set-stream-timeout-policy(set-stream-timeout-policy-payload),
        write-stdout(string),
        complete-task,
        get-dag,
        ask-human-approval(string),
        report-token-usage(report-token-usage-payload),
        spawn-mcp-server(spawn-mcp-server-payload),
        send-mcp-request(send-mcp-request-payload),
        get-repo-map,
        get-tools,
        execute-tool(execute-tool-payload),
    }

    record execute-tool-payload {
        call-id: string,
        name: string,
        arguments: string,
    }

    record spawn-mcp-server-payload {
        name: string,
        command: string,
        args: list<string>,
    }

    record send-mcp-request-payload {
        name: string,
        message: string,
    }

    record file-write-payload {
        path: string,
        data: list<u8>,
    }

    record file-patch-payload {
        path: string,
        diff: string,
    }

    record create-node-payload {
        parent-id: string,
        node-type: string,
    }

    record set-node-text-payload {
        node-id: string,
        text: string,
    }

    record merge-nodes-payload {
        node-ids: list<string>,
        summary-text: string,
    }

    record take-snapshot-payload {
        node-id: string,
        target-paths: list<string>,
    }

    record open-http-stream-payload {
        url: string,
        headers: list<tuple<string, string>>,
        body: string,
    }

    record set-stream-timeout-policy-payload {
        target: target,
        policy: timeout-policy,
    }

    record report-token-usage-payload {
        prompt-tokens: u32,
        completion-tokens: u32,
    }

    resource stream-handle {
        read: func(max-bytes: u32) -> result<list<u8>, string>;
        write: func(data: list<u8>) -> result<_, string>;
        close: func();
    }

    resource file-handle {
        read-at: func(offset: u64, len: u32) -> result<list<u8>, string>;
        write-at: func(offset: u64, data: list<u8>) -> result<_, string>;
        get-stream: func() -> stream-handle;
    }

    resource execution-handle {
        get-stdout: func() -> stream-handle;
        get-stderr: func() -> stream-handle;
        get-stdin: func() -> stream-handle;
        wait: func() -> result<s32, string>;
        kill: func();
    }
}

world rad-extension {
    use types.{ras-rpc-command, ras-core-event, stream-handle, file-handle, execution-handle};
    
    // host functions that the extension can call
    import host-rpc: func(command: ras-rpc-command) -> result<string, string>;
    
    import open-file: func(path: string, writeable: bool) -> result<file-handle, string>;
    import open-process: func(command: string) -> result<execution-handle, string>;
    import execute-tool: func(name: string, arguments: string) -> result<execution-handle, string>;
    import open-http-stream: func(url: string, headers: list<tuple<string, string>>, body: string) -> result<stream-handle, string>;

    // guest functions exported by the extension
    export on-event: func(event: ras-core-event) -> result<_, string>;
    export verify-rpc: func(command: ras-rpc-command) -> bool;
}

world rad-orchestrator {
    use types.{ras-rpc-command, ras-core-event, stream-handle, file-handle, execution-handle};
    
    import host-rpc: func(command: ras-rpc-command) -> result<string, string>;
    
    import open-file: func(path: string, writeable: bool) -> result<file-handle, string>;
    import open-process: func(command: string) -> result<execution-handle, string>;
    import execute-tool: func(name: string, arguments: string) -> result<execution-handle, string>;
    import open-http-stream: func(url: string, headers: list<tuple<string, string>>, body: string) -> result<stream-handle, string>;

    export on-event: func(event: ras-core-event) -> result<_, string>;
}

world rad-security-guard {
    use types.{ras-rpc-command, stream-handle, file-handle, execution-handle};
    
    import host-rpc: func(command: ras-rpc-command) -> result<string, string>;
    export verify-rpc: func(command: ras-rpc-command) -> bool;
}

world rad-tool-provider {
    use types.{ras-rpc-command, stream-handle, file-handle, execution-handle};
    
    import host-rpc: func(command: ras-rpc-command) -> result<string, string>;
    
    import open-file: func(path: string, writeable: bool) -> result<file-handle, string>;
    import open-process: func(command: string) -> result<execution-handle, string>;
    import execute-tool: func(name: string, arguments: string) -> result<execution-handle, string>;
    import open-http-stream: func(url: string, headers: list<tuple<string, string>>, body: string) -> result<stream-handle, string>;

    export get-tools: func() -> result<string, string>;
    export execute-tool: func(name: string, arguments: string) -> result<execution-handle, string>;
}
