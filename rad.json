{
  "core": {
    "workspace_dir": ".",
    "snapshot_dir": ".rad/snapshots",
    "log_dir": ".rad/logs"
  },
  "extensions": [
    {
      "name": "openai-orchestrator",
      "source": "target/wasm32-wasip2/release/openai_orchestrator.wasm",
      "enabled": true,
      "permissions": {
        "fs_read_allow": ["*"],
        "fs_write_allow": ["*"],
        "network": {
          "allow_network": true,
          "allow_domains": ["*"]
        }
      }
    },
    {
      "name": "rust-template-extension",
      "source": "target/wasm32-wasip2/release/rad_extension_template.wasm",
      "enabled": true,
      "role": "extension",
      "permissions": {
        "fs_read_allow": ["*"],
        "fs_write_allow": ["*"],
        "rpc_allow": ["WriteStdout"]
      }
    },
    {
      "name": "security-guard",
      "source": "target/wasm32-wasip2/release/security_guard.wasm",
      "enabled": true,
      "role": "security",
      "permissions": {
        "fs_read_allow": ["*"]
      }
    },
    {
      "name": "mcp-tool-provider",
      "source": "target/wasm32-wasip2/release/mcp_tool_provider.wasm",
      "enabled": true,
      "role": "tool-provider",
      "permissions": {
        "fs_read_allow": ["*"],
        "execution": {
          "allow_bash": true,
          "allow_commands": [],
          "block_commands": []
        }
      }
    },
    {
      "name": "openai-connector",
      "source": "target/wasm32-wasip2/release/openai_connector.wasm",
      "enabled": true,
      "role": "llm-connector",
      "permissions": {
        "fs_read_allow": ["*"],
        "fs_write_allow": ["*"],
        "network": {
          "allow_network": true,
          "allow_domains": ["*"]
        }
      }
    },
    {
      "name": "context-tools",
      "source": "target/wasm32-wasip2/release/context_tools.wasm",
      "enabled": true,
      "role": "context-tools",
      "permissions": {
        "fs_read_allow": ["*"],
        "fs_write_allow": ["*"]
      }
    }
  ]
}

