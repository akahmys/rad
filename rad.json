{
  // rad コアの動作ディレクトリ関連設定
  "core": {
    // エージェントが物理操作を行う作業領域のルートパス（省略時は "."）
    "workspace_dir": ".",
    // ファイルシステムのスナップショットデータを保存するディレクトリ（省略時は ".rad/snapshots"）
    "snapshot_dir": ".rad/snapshots",
    // 実行ログやセッションログの出力先ディレクトリ（省略時は ".rad/logs"）
    "log_dir": ".rad/logs"
  },

  // コアのデフォルトタイムアウト監視値（ミリ秒単位）
  "default_timeout": {
    // LLMから次のトークンが届くまでの最大沈黙許容時間（省略時は 15000 = 15秒）
    "llm_stream_heartbeat_ms": 15000,
    // 起動したプロセスが無反応になってからタイムアウトと見なすまでの時間（省略時は 60000 = 60秒）
    "process_silent_timeout_ms": 60000
  },

  // 起動・登録するエクステンション（ポリシー層）のリスト
  "extensions": [
    {
      // エクステンションの識別名
      "name": "standard-orchestrator",
      // エクステンションの所在（"builtin://" スキーマ、またはローカルWasmへの相対/絶対パス）
      "source": "builtin://standard-orchestrator",
      // このエクステンションを有効化して起動するかどうか
      "enabled": true,
      // エクステンションに付与する物理プリミティブの権限制限（Capability Mask）
      // ※ビルトインの場合はデフォルトでフル権限となります
      "permissions": {
        // 読み込みを許可するディレクトリパスのリスト（"*" はすべて許可）
        "fs_read_allow": ["*"],
        // 書き込みを許可するディレクトリパスのリスト（"*" はすべて許可）
        "fs_write_allow": ["*"],
        // bash コマンドの実行（spawn_bash_process）を許可するかどうか
        "allow_bash": true,
        // 外部インターネットへのHTTPストリーム接続等を許可するかどうか
        "allow_network": true
      },
      // エクステンションに透過的（Passthrough）に渡される固有の設定パラメータ
      "config": {
        // 使用するLLMのモデル名
        "model": "claude-3-5-sonnet-20241022",
        // 接続先APIエンドポイント（省略時は各エクステンションのデフォルト）
        "api_base": "https://api.anthropic.com",
        // LLM生成時の出力多様性パラメータ
        "temperature": 0.2
      }
    }
  ]
}
